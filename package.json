{
  "name": "code-guardian-ai-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "backend:setup": "python -m pip install -r backend/requirements.txt",
    "backend:dev": "python -m uvicorn app.main:app --reload --port 8081 --app-dir backend",
    "backend:compile": "python -m compileall backend/app",
    "dev": "concurrently -k -n frontend,backend -c cyan,green \"npm run frontend:dev\" \"npm run backend:dev\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
